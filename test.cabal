cabal-version:       3.0
name:                test
version:             0.1.0.0
build-type:          Simple

executable test
  main-is:           Main.hs
  other-modules:     App.Core.Config
                   , App.Core.Env
                   , App.Infrastructure.DB.Types
                   , App.Infrastructure.DB.SQLite
                   , App.Infrastructure.DB.SqlServer
                   , App.Infrastructure.DB.Redis
                   , App.Infrastructure.Logger.CsvLogger
                   , App.Infrastructure.Logger.CsvLogger2
                   , App.Middleware.TokenAuth
                   , App.Auth.UserStore
                   , App.Auth.Handler
                   , App.Server.API
                   , App.Server.Router
                   , App.API.Greeting.API
                   , App.API.Greeting.Types
                   , App.API.Greeting.Handler.Position
                   , App.API.Greeting.Handler.Hello
                   , App.API.Marketing.API
                   , App.API.Marketing.Types
                   , App.API.Marketing.Handler
                   , App.API.Person.API
                   , App.API.Person.Types
                   , App.API.Person.Handler.Age
                   , App.API.Person.Handler.Name
                   , App.API.Person.Handler.Name2
                   , App.API.Person.Handler.WithError
                   , App.API.Message.API
                   , App.API.Message.Handler.Post
                   , App.API.Message.Handler.Get
                   , App.API.SqlServerDemo.API
                   , App.API.SqlServerDemo.Handler.Get
                   , App.API.SqlServerDemo.Handler.Post
                   , App.API.Redis.API
                   , App.API.Redis.Handler.Get
  hs-source-dirs:    src
  default-language:  Haskell2010
  ghc-options:       -Wall -threaded

  build-depends:
      base           >= 4.7 && < 5
    , aeson
    , servant-server
    , wai
    , warp
    , time
    , wai-cors
    , http-types
    , mtl
    , bytestring
    , sqlite-simple
    , mssql-simple
    , network
    , resource-pool
    , hedis
    , containers
    , text
    , http-client
    , servant-client
    , uuid
