cabal-version:       3.0
name:                test
version:             0.1.0.0
build-type:          Simple

executable test
  main-is:           Main.hs
  other-modules:     App.Types
                   , App.API
                   , App.Config
                   , App.Server
                   , App.Server1
                   , App.Server2
                   , App.Server3
                   , App.Server4
                   , App.DB
  hs-source-dirs:    src
  default-language:  Haskell2010
  ghc-options:       -Wall -threaded

  build-depends:
      base           >= 4.7 && < 5
    , aeson
    , servant-server
    , wai
    , warp
    , time
    , wai-cors
    , http-types
    , mtl
    , bytestring
    , sqlite-simple
    , mssql-simple
    , network
    , resource-pool
