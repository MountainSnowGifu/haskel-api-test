cabal-version:       3.0
name:                test
version:             0.1.0.0
build-type:          Simple

executable test
  main-is:           Main.hs
  other-modules:     App.Config
                   , App.Middleware.CsvLogger
                   , App.Middleware.CsvLogger2
                   , App.Middleware.TokenAuth
                   , App.Env
                   , App.API
                   , App.Server
                   , App.DB
                   , App.DB.Types
                   , App.DB.SqlserverPool
                   , App.DB.SQLiteDB
                   , App.Greeting.API
                   , App.Greeting.Types
                   , App.Greeting.Handler.Position
                   , App.Greeting.Handler.Hello
                   , App.Marketing.API
                   , App.Marketing.Types
                   , App.Marketing.Handler
                   , App.Person.API
                   , App.Person.Types
                   , App.Person.Handler.Age
                   , App.Person.Handler.Name
                   , App.Person.Handler.Name2
                   , App.Person.Handler.WithError
                   , App.Message.API
                   , App.Message.Handler.Post
                   , App.Message.Handler.Get
                   , App.SqlServer.API
                   , App.SqlServer.Handler.Get
                   , App.SqlServer.Handler.Post
                   , App.DB.RedisPool
                   , App.RedisTest.API
                   , App.RedisTest.Handler.RedisGet
                   , App.Auth.BasicAuth
                   , App.Auth.Auth
  hs-source-dirs:    src
  default-language:  Haskell2010
  ghc-options:       -Wall -threaded

  build-depends:
      base           >= 4.7 && < 5
    , aeson
    , servant-server
    , wai
    , warp
    , time
    , wai-cors
    , http-types
    , mtl
    , bytestring
    , sqlite-simple
    , mssql-simple
    , network
    , resource-pool
    , hedis
    , containers
    , text
    , http-client
    , servant-client
    , uuid
